{
  "name": "copilot-resurrect",
  "displayName": "Copilot Resurrect",
  "description": "Automatically resurrects a dead GitHub Copilot Chat session by re-injecting your configured ignition prompt — keep autonomous coding loops alive overnight.",
  "version": "1.0.0",
  "publisher": "EricAnderson",
  "repository": {
    "type": "git",
    "url": "https://github.com/EricAnderson/copilot-resurrect"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "keywords": [
    "copilot",
    "chat",
    "resurrect",
    "watchdog",
    "autonomous",
    "agent"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Copilot Resurrect",
      "properties": {
        "copilot-resurrect.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable/disable the Copilot session resurrection watcher. When enabled, the watcher will automatically restart a dead Copilot Chat session using your ignition prompt."
        },
        "copilot-resurrect.ignitionPrompt": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "The prompt to inject when resurrecting a dead Copilot Chat session. This should be your autonomous loop ignition prompt (e.g. 'Pull open backlog items from GitHub Issues, implement and commit them, then loop.')."
        },
        "copilot-resurrect.silenceTimeoutSeconds": {
          "type": "number",
          "default": 180,
          "minimum": 60,
          "maximum": 600,
          "description": "How many seconds of silence before declaring the Copilot Chat session dead and triggering resurrection. Default: 180s (3 minutes). Increase if your model takes very long to respond."
        },
        "copilot-resurrect.maxRestartsPerDay": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 200,
          "description": "Maximum number of automatic session resurrections allowed per calendar day. Prevents infinite-loop storms. Default: 50."
        },
        "copilot-resurrect.modelHint": {
          "type": "string",
          "default": "",
          "description": "Optional model hint prepended to the ignition prompt (e.g. '@gpt-4o'). Leave blank to use whatever model Copilot Chat selects by default."
        },
        "copilot-resurrect.watchPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Override the list of file-system paths the watcher monitors for Copilot Chat activity. Leave empty for automatic discovery (recommended)."
        }
      }
    },
    "commands": [
      {
        "command": "copilot-resurrect.enable",
        "title": "Copilot Resurrect: Enable Watcher",
        "category": "Copilot Resurrect"
      },
      {
        "command": "copilot-resurrect.disable",
        "title": "Copilot Resurrect: Disable Watcher",
        "category": "Copilot Resurrect"
      },
      {
        "command": "copilot-resurrect.toggle",
        "title": "Copilot Resurrect: Toggle Watcher",
        "category": "Copilot Resurrect"
      },
      {
        "command": "copilot-resurrect.testResurrection",
        "title": "Copilot Resurrect: Test Resurrection (dry run)",
        "category": "Copilot Resurrect"
      },
      {
        "command": "copilot-resurrect.status",
        "title": "Copilot Resurrect: Show Status",
        "category": "Copilot Resurrect"
      },
      {
        "command": "copilot-resurrect.resetDailyCounter",
        "title": "Copilot Resurrect: Reset Daily Restart Counter",
        "category": "Copilot Resurrect"
      },
      {
        "command": "copilot-resurrect.showLog",
        "title": "Copilot Resurrect: Show Output Log",
        "category": "Copilot Resurrect"
      },
      {
        "command": "copilot-resurrect.configurePrompt",
        "title": "Copilot Resurrect: Configure Ignition Prompt",
        "category": "Copilot Resurrect"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "copilot-resurrect.enable",
          "when": "true"
        },
        {
          "command": "copilot-resurrect.disable",
          "when": "true"
        },
        {
          "command": "copilot-resurrect.toggle",
          "when": "true"
        },
        {
          "command": "copilot-resurrect.testResurrection",
          "when": "true"
        },
        {
          "command": "copilot-resurrect.status",
          "when": "true"
        },
        {
          "command": "copilot-resurrect.resetDailyCounter",
          "when": "true"
        },
        {
          "command": "copilot-resurrect.showLog",
          "when": "true"
        },
        {
          "command": "copilot-resurrect.configurePrompt",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
